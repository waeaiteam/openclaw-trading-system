[Unit]
Description=OpenClaw Coevo Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/openclaw-trading-system/src
EnvironmentFile=-/root/openclaw-trading-system/.env
ExecStart=/usr/bin/python3 /root/openclaw-trading-system/src/coevo_dashboard.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
